<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ToDoTime" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/amber_primary</item>
        <item name="colorSecondary">@color/amber_primary</item>
        <item name="android:statusBarColor">@color/cream_background</item>
        <item name="android:navigationBarColor">@color/cream_background</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/cream_background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ToDoTime</item>
    </style>
</resources>
